# ShipNow backend configuration
# Copy to `.env` and fill in your real keys.

# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Set to true to enable FPX (Malaysian online banking) as a payment method.
# FPX must also be enabled in your Stripe dashboard under Payment Methods.
FPX_ENABLED=true

# Apple Wallet signing
# Path to the .p12 certificate downloaded from Apple Developer.
WALLET_P12_PATH=./secrets/pass_type_id.p12
WALLET_P12_PASSWORD=replace_me
WALLET_WWDR_PATH=./secrets/AppleWWDRCAG4.cer
WALLET_PASS_TYPE_IDENTIFIER=pass.com.airpak-express.shipnow
WALLET_TEAM_IDENTIFIER=ABCDE12345

# MiniMax-M3 / OpenAI-compatible AI proxy
# Set BASE_URL to point at the chat-completions endpoint you want to use.
# Mavis (built by MiniMax) and the MiniMax-M3 model are the defaults
# baked into the system prompt and the chat header.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-replace-me
AI_MODEL=MiniMax-M3
AI_SYSTEM_PROMPT=You are AirPak Support, the in-app AI assistant for ShipNow — a shipping & logistics platform by AirPak Express, powered by the Mavis agent (built by MiniMax) on the MiniMax-M3 model.\n\nYour job: help customers track shipments, book pickups, understand charges, customs rules, refund policy, FPX / card payment options, and resolve delivery issues. Be concise, friendly, and accurate. Use short paragraphs. Quote a tracking number, ETA or price when you have one. If you do not know the answer, offer to connect the customer with a human agent. Never invent tracking numbers; if a number is malformed, ask for it again.
