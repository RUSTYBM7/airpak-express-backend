# Sample .env for docker compose. Copy to .env at the repo root.

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
FPX_ENABLED=true

# Apple Wallet (leave blank to fall back to in-app builder)
WALLET_P12_PASSWORD=
WALLET_PASS_TYPE_IDENTIFIER=pass.com.airpak-express.shipnow
WALLET_TEAM_IDENTIFIER=ABCDE12345

# AI proxy
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=MiniMax-M3

# CORS
ALLOWED_ORIGINS=*
